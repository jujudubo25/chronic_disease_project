q_race_summary <- "
SELECT
RaceGroup,
COUNT(*) AS n,
SUM(CASE WHEN Diabetes = 1 THEN 1 ELSE 0 END) AS diabetes_count,
AVG(CASE WHEN Diabetes = 1 THEN 1.0 ELSE 0 END) AS diabetes_prop
FROM race_lookup
GROUP BY RaceGroup;
"
dbGetQuery(con, q_race_summary)
