q_age_crosstab <- "
SELECT CASE
WHEN Age < 30 then '<30',
WHEN Age BETWEEN 30 and 44 then '30-44',
WHEN Age BETWEEN 45 and 45 then '45-49',
WHEN age > 60 then '60+'
END as age_band
COUNT(*) AS n,
SUM(CASE WHEN Hypertension = 1 THEN 1 ELSE 0 END) AS htn_count,
AVG(CASE WHEN Hypertension = 1 THEN 1.0 ELSE 0 END) AS htn_prop
FROM individuals_clinic
GROUP BY age_band
ORDER BY
CASE age_band
WHEN '<30' THEN 1
WHEN '30–44' THEN 2
WHEN '45–59' THEN 3
WHEN '60+' THEN 4
END;
"
dbGetQuery(con, q_age_htn)
